# DotBridge — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Deployer private key (MetaMask account with testnet WND)
# Get testnet WND from: https://faucet.polkadot.io/westend
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# Enable gas reporting in tests
REPORT_GAS=true

# Hyperbridge Gateway address on Westend Hub testnet
# Leave as address(0) for mock mode until official address is published
# Check: https://docs.hyperbridge.network/developers/evm/token-gateway
HYPERBRIDGE_GATEWAY=0x0000000000000000000000000000000000000000
