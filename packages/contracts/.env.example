# ============================================================
# DotBridge — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# Your deployer wallet private key (with 0x prefix)
# Fund this address with WND from: https://faucet.polkadot.io/westend
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC overrides (optional — defaults already set in hardhat.config.js)
# WESTEND_RPC=https://westend-asset-hub-eth-rpc.polkadot.io
# POLKADOT_RPC=https://asset-hub-polkadot-eth-rpc.polkadot.io

# Set to any value to enable gas reporting in tests
# REPORT_GAS=true

# Deployed contract addresses (filled in after deploy.js runs)
# These are used by the frontend and verify script.
WDOT_ADDRESS=
PRICE_ORACLE_ADDRESS=
COLLATERAL_VAULT_ADDRESS=
LENDING_POOL_ADDRESS=
REMITTANCE_BRIDGE_ADDRESS=
MOCK_USDC_ADDRESS=

# Hyperbridge Token Gateway address on Westend testnet
# Check: https://docs.hyperbridge.network/for-users/bridges/polkadot
HYPERBRIDGE_GATEWAY_WESTEND=0x0000000000000000000000000000000000000000
HYPERBRIDGE_GATEWAY_MAINNET=0x0000000000000000000000000000000000000000
